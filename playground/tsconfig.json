{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@fast/tokens": ["../packages/tokens/src"],
      "@fast/tokens/*": ["../packages/tokens/src/*"],
      "@fast/mui-theme": ["../packages/mui-theme/src"],
      "@fast/mui-theme/*": ["../packages/mui-theme/src/*"],
      "@fast/components": ["../packages/components/src"],
      "@fast/components/*": ["../packages/components/src/*"]
    }
  },
  "include": ["src"]
}
